# Data source: memory (demo) | mongodb (Atlas)
DATA_SOURCE=memory

# Dev auto-reload (optional; also set in .env.development)
# WATCHPACK_POLLING=true
# CHOKIDAR_USEPOLLING=true

# MongoDB Atlas (phase 2)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=puma

# AI planner (/assistant) — uses the Anthropic API
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-haiku-4-5)
# ASSISTANT_MODEL=claude-haiku-4-5
