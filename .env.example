# Data source: memory (demo) | mongodb (Atlas)
# Tip: use DATA_SOURCE=memory in .env.development.local for fast local dev.
# .env.local overrides .env.development, so Atlas settings there always win.
DATA_SOURCE=memory

# Dev auto-reload (optional; also set in .env.development)
# WATCHPACK_POLLING=true
# CHOKIDAR_USEPOLLING=true

# MongoDB Atlas (phase 2)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=puma

# AI planner (/assistant) — uses the Anthropic API
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-haiku-4-5)
# ASSISTANT_MODEL=claude-haiku-4-5

# Auth (Better Auth) — required when DATA_SOURCE=mongodb
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Public base URL in production (defaults to http://localhost:3000)
# BETTER_AUTH_URL=https://puma.example.com

# ── Hosted mode (optional — self-hosted installs leave all of this unset) ───
# When BILLING_ENABLED=1 the app gates sign-ins on a `subscriptions` row
# (written by your own external billing service) or the OWNER_EMAILS allowlist.
# BILLING_ENABLED=1
# OWNER_EMAILS=you@example.com
# Where anonymous visitors at "/" are sent (e.g. a marketing page another
# service renders behind the same reverse proxy). Unset → straight to /login.
# MARKETING_HOME=/landing
