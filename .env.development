# Dev-only: poll for file changes when native watchers miss edits (VM, Docker, some IDEs).
# Polling makes the dev server feel sluggish — only enable if hot reload is broken.
# WATCHPACK_POLLING=true
# CHOKIDAR_USEPOLLING=true

# Fast local dev: create .env.development.local with DATA_SOURCE=memory
# (.env.local's DATA_SOURCE=mongodb wins over this file if set there)
